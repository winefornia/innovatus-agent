# Anthropic (LLM for extraction, clarification, edit parsing)
ANTHROPIC_API_KEY=

# Square — Production
SQUARE_PROD_ACCESS_TOKEN=
SQUARE_PROD_LOCATION_ID=

# Square — Sandbox (for local dev/testing)
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=

# Telegram bots
TELEGRAM_BOT_TOKEN=                      # @BotFather → invoice bot (primary interface)
TELEGRAM_TASTINGROOM_BOT_TOKEN=          # @BotFather → tasting room bot
TELEGRAM_APPROVAL_CHAT_ID=              # Telegram chat ID for tasting room approval prompts
TELEGRAM_TASTINGROOM_AUTHORIZED_CHAT_IDS= # Optional comma-separated chat IDs; defaults to TELEGRAM_APPROVAL_CHAT_ID
TELEGRAM_TASTINGROOM_AUTHORIZED_USER_IDS= # Optional comma-separated Telegram user IDs

# Supabase (database + LangGraph checkpointer)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Use pgBouncer port 6543, NOT direct 5432 (blocked externally on Supabase)
POSTGRES_CONNECTION_STRING=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres

# Gmail OAuth (base64-encoded token.json — run scripts/google_auth.py to generate)
GMAIL_TOKEN_JSON_B64=
# Deploy via: flyctl secrets set GMAIL_TOKEN_JSON_B64=$(base64 -i token.json)
GMAIL_INTAKE_LABEL=To Invoice
GMAIL_TASTING_LABEL=Tasting Requests

# Mem0 (persistent skill memory across sessions — optional)
MEM0_API_KEY=

# Tasting room safety
# true = all outbound emails go to TASTINGROOM_TEST_RECIPIENT, not real recipients
TASTINGROOM_SAFE_MODE=true
TASTINGROOM_TEST_RECIPIENT=your-test-email@example.com

# Google authorized accounts (comma-separated; controls Google Chat access)
# GOOGLE_AUTHORIZED_ACCOUNTS=lisa@innovatuswine.com,cecil.park@winefornia.com

# LangSmith (observability — optional)
# LANGCHAIN_API_KEY=
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=winefornia-invoice-agent
